---
import Base from '../layouts/Base.astro';
---
<Base
  title="Your bag — Candle Atelier"
  description="Review your selection and proceed to checkout."
>
  <section class="mx-auto max-w-5xl px-6 py-16 md:px-10 md:py-24">
    <div class="mb-10 border-b border-[color:var(--color-ink-line)] pb-6">
      <div class="text-[11px] uppercase tracking-[0.32em] text-[color:var(--color-bone-mute)]">Checkout · Step 1 of 2</div>
      <h1 class="mt-3 font-[family-name:var(--font-display)] text-5xl text-[color:var(--color-bone)]">Your bag</h1>
    </div>

    <div id="empty-state" class="hidden border border-dashed border-[color:var(--color-ink-line)] py-20 text-center">
      <div class="font-[family-name:var(--font-display)] text-3xl text-[color:var(--color-bone)]">Nothing yet.</div>
      <p class="mt-3 text-[color:var(--color-bone-mute)]">Your bag is empty.</p>
      <a href="/shop" class="btn btn-primary mt-8">Browse the four</a>
    </div>

    <div id="cart-wrap" class="grid gap-10 lg:grid-cols-[1.5fr_1fr] lg:gap-16">
      <div>
        <div id="items" class="divide-y divide-[color:var(--color-ink-line)] border-y border-[color:var(--color-ink-line)]"></div>
      </div>

      <aside class="h-fit border border-[color:var(--color-ink-line)] bg-[color:var(--color-ink-soft)] p-6">
        <div class="text-[11px] uppercase tracking-[0.22em] text-[color:var(--color-bone-mute)]">Summary</div>

        <dl class="mt-6 space-y-3 text-sm">
          <div class="flex justify-between">
            <dt class="text-[color:var(--color-bone-dim)]">Subtotal</dt>
            <dd id="subtotal" class="tabular-nums text-[color:var(--color-bone)]">£0.00</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-[color:var(--color-bone-dim)]">Shipping</dt>
            <dd id="shipping" class="tabular-nums text-[color:var(--color-bone)]">£4.95</dd>
          </div>
          <div class="flex justify-between border-t border-[color:var(--color-ink-line)] pt-3">
            <dt class="uppercase tracking-[0.2em] text-[10px] text-[color:var(--color-bone-mute)] self-end">Total</dt>
            <dd id="total" class="text-xl tabular-nums text-[color:var(--color-ember)]">£4.95</dd>
          </div>
        </dl>

        <button id="checkout-btn" class="btn btn-primary mt-8 w-full">Proceed to checkout</button>
        <p id="ship-hint" class="mt-3 text-center text-[10px] uppercase tracking-[0.2em] text-[color:var(--color-bone-mute)]">Free UK shipping over £60</p>

        <div class="mt-6 flex items-center justify-center gap-2 text-[10px] uppercase tracking-[0.22em] text-[color:var(--color-bone-mute)]">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          Secure checkout by Stripe
        </div>
      </aside>
    </div>
  </section>

  <script>
    type CartItem = {
      id: string; slug: string; name: string;
      price_pence: number; image_url?: string; quantity: number;
    };

    const fmt = (p: number) => new Intl.NumberFormat('en-GB', { style: 'currency', currency: 'GBP' }).format(p / 100);

    const itemsEl = document.getElementById('items')!;
    const emptyEl = document.getElementById('empty-state')!;
    const wrapEl = document.getElementById('cart-wrap')!;
    const subEl = document.getElementById('subtotal')!;
    const shipEl = document.getElementById('shipping')!;
    const totalEl = document.getElementById('total')!;
    const btn = document.getElementById('checkout-btn') as HTMLButtonElement;
    const shipHint = document.getElementById('ship-hint')!;

    function readCart(): CartItem[] {
      try { return JSON.parse(localStorage.getItem('cart') || '[]'); } catch { return []; }
    }
    function writeCart(c: CartItem[]) {
      localStorage.setItem('cart', JSON.stringify(c));
      window.dispatchEvent(new Event('cart:updated'));
      render();
    }

    function render() {
      const cart = readCart();
      if (!cart.length) {
        emptyEl.classList.remove('hidden');
        wrapEl.classList.add('hidden');
        return;
      }
      emptyEl.classList.add('hidden');
      wrapEl.classList.remove('hidden');

      itemsEl.innerHTML = cart.map((item, idx) => `
        <div class="flex gap-5 py-6">
          <a href="/shop/${item.slug}" class="block h-24 w-20 shrink-0 overflow-hidden border border-[color:var(--color-ink-line)] bg-[color:var(--color-ink-soft)]">
            ${item.image_url ? `<img src="${item.image_url}" alt="${item.name}" class="h-full w-full object-cover" />` : ''}
          </a>
          <div class="flex flex-1 flex-col justify-between">
            <div class="flex items-start justify-between">
              <div>
                <a href="/shop/${item.slug}" class="font-[family-name:var(--font-display)] text-xl text-[color:var(--color-bone)] hover:text-[color:var(--color-ember)]">${item.name}</a>
                <div class="mt-1 text-[10px] uppercase tracking-[0.24em] text-[color:var(--color-bone-mute)]">${fmt(item.price_pence)} each</div>
              </div>
              <div class="text-lg tabular-nums text-[color:var(--color-ember)]">${fmt(item.price_pence * item.quantity)}</div>
            </div>
            <div class="flex items-center justify-between">
              <div class="flex items-center border border-[color:var(--color-ink-line)]">
                <button data-dec="${idx}" class="h-9 w-9 text-[color:var(--color-bone-dim)] hover:text-[color:var(--color-ember)]">−</button>
                <span class="w-8 text-center text-sm text-[color:var(--color-bone)]">${item.quantity}</span>
                <button data-inc="${idx}" class="h-9 w-9 text-[color:var(--color-bone-dim)] hover:text-[color:var(--color-ember)]">+</button>
              </div>
              <button data-remove="${idx}" class="text-[10px] uppercase tracking-[0.24em] text-[color:var(--color-bone-mute)] hover:text-[color:var(--color-ember)]">Remove</button>
            </div>
          </div>
        </div>
      `).join('');

      const subtotal = cart.reduce((a, b) => a + b.price_pence * b.quantity, 0);
      const shipping = subtotal >= 6000 ? 0 : 495;
      const total = subtotal + shipping;

      subEl.textContent = fmt(subtotal);
      shipEl.textContent = shipping === 0 ? 'Free' : fmt(shipping);
      totalEl.textContent = fmt(total);
      shipHint.textContent = shipping === 0 ? 'Free shipping applied' : `Free UK shipping over £60 (add ${fmt(6000 - subtotal)})`;

      itemsEl.querySelectorAll<HTMLButtonElement>('[data-inc]').forEach((b) =>
        b.addEventListener('click', () => {
          const i = Number(b.dataset.inc); const c = readCart();
          c[i].quantity = Math.min(20, c[i].quantity + 1); writeCart(c);
        }),
      );
      itemsEl.querySelectorAll<HTMLButtonElement>('[data-dec]').forEach((b) =>
        b.addEventListener('click', () => {
          const i = Number(b.dataset.dec); const c = readCart();
          c[i].quantity = Math.max(1, c[i].quantity - 1); writeCart(c);
        }),
      );
      itemsEl.querySelectorAll<HTMLButtonElement>('[data-remove]').forEach((b) =>
        b.addEventListener('click', () => {
          const i = Number(b.dataset.remove); const c = readCart();
          c.splice(i, 1); writeCart(c);
        }),
      );
    }

    btn.addEventListener('click', async () => {
      const cart = readCart();
      if (!cart.length) return;
      btn.disabled = true;
      btn.textContent = 'Preparing checkout…';
      try {
        const res = await fetch('/api/checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            items: cart.map((c) => ({ id: c.id, quantity: c.quantity })),
          }),
        });
        const json = await res.json();
        if (!res.ok || !json.url) throw new Error(json.error || 'Checkout failed');
        window.location.href = json.url;
      } catch (e: any) {
        btn.disabled = false;
        btn.textContent = 'Proceed to checkout';
        alert(e.message || 'Sorry, checkout failed.');
      }
    });

    render();
  </script>
</Base>
