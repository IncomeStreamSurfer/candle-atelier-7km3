---
import Base from '../../layouts/Base.astro';
import { getProductBySlug, getActiveProducts } from '../../lib/supabase';
import { formatMoney } from '../../lib/format';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/shop');

const product = await getProductBySlug(slug);
if (!product) return Astro.redirect('/shop');

const all = await getActiveProducts();
const others = all.filter((p) => p.id !== product.id).slice(0, 3);
const siteUrl = (import.meta.env.PUBLIC_SITE_URL as string) || Astro.url.origin;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: product.description,
  image: product.image_url,
  sku: product.slug,
  brand: { '@type': 'Brand', name: 'Candle Atelier' },
  offers: {
    '@type': 'Offer',
    url: new URL(`/shop/${product.slug}`, siteUrl).toString(),
    price: (product.price_pence / 100).toFixed(2),
    priceCurrency: product.currency.toUpperCase(),
    availability: 'https://schema.org/InStock',
  },
};
---
<Base
  title={`${product.name} — Candle Atelier`}
  description={product.description}
  image={product.image_url || undefined}
  jsonLd={jsonLd}
>
  <section class="mx-auto max-w-7xl px-6 py-14 md:px-10 md:py-20">
    <a href="/shop" class="mb-10 inline-flex items-center gap-2 text-[11px] uppercase tracking-[0.22em] text-[color:var(--color-bone-mute)] hover:text-[color:var(--color-ember)]">
      <span>←</span> All candles
    </a>

    <div class="grid gap-12 md:grid-cols-2 md:gap-16">
      <div class="relative">
        <div class="aspect-[4/5] overflow-hidden border border-[color:var(--color-ink-line)] bg-[color:var(--color-ink-soft)]">
          {product.image_url && (
            <img src={product.image_url} alt={product.name} class="h-full w-full object-cover" />
          )}
        </div>
      </div>

      <div class="flex flex-col justify-center">
        <div class="text-[11px] uppercase tracking-[0.32em] text-[color:var(--color-bone-mute)]">{product.scent_profile}</div>
        <h1 class="mt-3 font-[family-name:var(--font-display)] text-5xl text-[color:var(--color-bone)] md:text-6xl">{product.name}</h1>
        <div class="mt-5 text-2xl text-[color:var(--color-ember)] tabular-nums">{formatMoney(product.price_pence, product.currency)}</div>

        <p class="mt-8 text-base leading-relaxed text-[color:var(--color-bone-dim)]">{product.description}</p>

        <dl class="mt-10 grid grid-cols-2 gap-6 border-t border-[color:var(--color-ink-line)] pt-6 text-sm">
          <div>
            <dt class="text-[10px] uppercase tracking-[0.28em] text-[color:var(--color-bone-mute)]">Notes</dt>
            <dd class="mt-1.5 text-[color:var(--color-bone)]">{product.notes}</dd>
          </div>
          <div>
            <dt class="text-[10px] uppercase tracking-[0.28em] text-[color:var(--color-bone-mute)]">Burn time</dt>
            <dd class="mt-1.5 text-[color:var(--color-bone)]">{product.burn_time}</dd>
          </div>
          <div>
            <dt class="text-[10px] uppercase tracking-[0.28em] text-[color:var(--color-bone-mute)]">Weight</dt>
            <dd class="mt-1.5 text-[color:var(--color-bone)]">{product.weight_g}g</dd>
          </div>
          <div>
            <dt class="text-[10px] uppercase tracking-[0.28em] text-[color:var(--color-bone-mute)]">Wax</dt>
            <dd class="mt-1.5 text-[color:var(--color-bone)]">Coconut-rapeseed</dd>
          </div>
        </dl>

        <div class="mt-10 flex items-center gap-3">
          <div class="flex items-center border border-[color:var(--color-ink-line)]">
            <button type="button" data-qty-dec class="h-12 w-12 text-lg text-[color:var(--color-bone-dim)] hover:text-[color:var(--color-ember)]">−</button>
            <input id="qty" type="number" min="1" max="20" value="1" class="h-12 w-14 bg-transparent text-center text-[color:var(--color-bone)] outline-none" />
            <button type="button" data-qty-inc class="h-12 w-12 text-lg text-[color:var(--color-bone-dim)] hover:text-[color:var(--color-ember)]">+</button>
          </div>
          <button
            id="add-to-bag"
            data-product-id={product.id}
            data-product-name={product.name}
            data-product-slug={product.slug}
            data-product-price={product.price_pence}
            data-product-image={product.image_url || ''}
            class="btn btn-primary flex-1"
          >
            Add to bag — {formatMoney(product.price_pence, product.currency)}
          </button>
        </div>
        <div class="mt-4 text-[11px] uppercase tracking-[0.22em] text-[color:var(--color-bone-mute)]">
          Free UK delivery over £60 · Ships in 3 working days
        </div>
      </div>
    </div>

    {others.length > 0 && (
      <div class="mt-24">
        <div class="mb-8 flex items-end justify-between border-b border-[color:var(--color-ink-line)] pb-4">
          <h2 class="font-[family-name:var(--font-display)] text-2xl text-[color:var(--color-bone)]">Also from the season</h2>
          <a href="/shop" class="text-[11px] uppercase tracking-[0.22em] text-[color:var(--color-bone-dim)] hover:text-[color:var(--color-ember)]">View all →</a>
        </div>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-3">
          {others.map((p) => (
            <a href={`/shop/${p.slug}`} class="group block border border-[color:var(--color-ink-line)] bg-[color:var(--color-ink-soft)] transition hover:border-[color:var(--color-ember)]">
              <div class="aspect-[4/5] overflow-hidden">
                {p.image_url && <img src={p.image_url} alt={p.name} class="h-full w-full object-cover transition-transform duration-1000 group-hover:scale-105" />}
              </div>
              <div class="flex items-baseline justify-between p-4">
                <div>
                  <div class="font-[family-name:var(--font-display)] text-lg text-[color:var(--color-bone)]">{p.name}</div>
                  <div class="mt-1 text-[10px] uppercase tracking-[0.2em] text-[color:var(--color-bone-mute)]">{p.scent_profile}</div>
                </div>
                <div class="text-[color:var(--color-ember)] tabular-nums">{formatMoney(p.price_pence, p.currency)}</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}
  </section>

  <script>
    const qty = document.getElementById('qty') as HTMLInputElement | null;
    const clamp = (v: number) => Math.max(1, Math.min(20, v || 1));
    document.querySelector('[data-qty-inc]')?.addEventListener('click', () => {
      if (!qty) return; qty.value = String(clamp(parseInt(qty.value || '1') + 1));
    });
    document.querySelector('[data-qty-dec]')?.addEventListener('click', () => {
      if (!qty) return; qty.value = String(clamp(parseInt(qty.value || '1') - 1));
    });

    const btn = document.getElementById('add-to-bag') as HTMLButtonElement | null;
    btn?.addEventListener('click', () => {
      if (!btn) return;
      const id = btn.dataset.productId!;
      const name = btn.dataset.productName!;
      const slug = btn.dataset.productSlug!;
      const price = parseInt(btn.dataset.productPrice || '0');
      const image = btn.dataset.productImage || '';
      const quantity = clamp(parseInt(qty?.value || '1'));

      const raw = localStorage.getItem('cart');
      let cart: any[] = [];
      try { cart = raw ? JSON.parse(raw) : []; } catch {}
      const existing = cart.find((i) => i.id === id);
      if (existing) existing.quantity += quantity;
      else cart.push({ id, slug, name, price_pence: price, image_url: image, quantity });
      localStorage.setItem('cart', JSON.stringify(cart));
      window.dispatchEvent(new Event('cart:updated'));

      const originalHtml = btn.innerHTML;
      btn.innerHTML = 'Added to bag ✓';
      btn.disabled = true;
      setTimeout(() => {
        btn.innerHTML = originalHtml;
        btn.disabled = false;
      }, 1400);
    });
  </script>
</Base>
